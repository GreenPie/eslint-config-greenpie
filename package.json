{
  "name": "eslint-config-greenpie",
  "version": "16.0.0-11",
  "description": "GreenPie's ESLint and oxlint configs",
  "main": "index.js",
  "author": "Roman Nuritdinov (Ky6uk)",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.14.1",
  "homepage": "https://github.com/GreenPie/eslint-config-greenpie",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreenPie/eslint-config-greenpie"
  },
  "bugs": {
    "url": "https://github.com/GreenPie/eslint-config-greenpie/issues"
  },
  "scripts": {
    "lint:eslint": "eslint",
    "lint:oxlint": "oxlint",
    "lint:oxlint:agent": "oxlint --format agent",
    "prepare": "husky",
    "test:agent": "vitest run --reporter=json",
    "test": "vitest run",
    "update:all": "taze -I -l --peer"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "greenpie",
    "config",
    "javascript",
    "styleguide",
    "typescript",
    "vue",
    "oxlint"
  ],
  "devDependencies": {
    "@types/node": "^25.7.0",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "oxlint": "^1.64.0",
    "taze": "^19.11.0",
    "valibot": "1.4.0",
    "vitest": "^4.1.6",
    "vue": "^3.5.34"
  },
  "peerDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript-eslint": "^8.59.3"
  }
}
